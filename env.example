# ─── Required API Keys ────────────────────────────────────────────────────────

# FlashParty API key — get yours at https://flashparty.co/developers
FLASHPARTY_API_KEY=fp_live_your_key_here

# PartyLab API key — get yours at https://partylab.dev
PARTYLAB_API_KEY=pl_your_key_here

# Anthropic API key — get yours at https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-your_key_here

# ─── Optional ─────────────────────────────────────────────────────────────────

# Name shown as the photo uploader in each party (default: "Party Bot")
UPLOADER_NICKNAME=Party Bot
